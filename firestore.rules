rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    // Role check: Bootstrapped admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ebsoftopd@gmail.com' ||
        request.auth.token.email == 'navil@radiographer.app' ||
        request.auth.token.email == 'kawsar@radiographer.app'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entities ---

    // Patient Records
    function isValidPatientRecord(data) {
      let required = ['date', 'name', 'userId', 'createdAt', 'age', 'invoice', 'filmType', 'count', 'radiographer', 'department', 'filmSize'];
      return data.keys().hasAll(required) &&
             data.date is string && data.date.size() <= 32 &&
             data.name is string && data.name.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.age is string && data.age.size() <= 20 &&
             data.invoice is string && data.invoice.size() <= 64 &&
             data.filmType is string && data.filmType.size() <= 64 &&
             data.count is number && data.count >= 0 && data.count <= 100 &&
             data.radiographer is string && data.radiographer.size() <= 128 &&
             data.department is string && data.department.size() <= 64 &&
             data.filmSize is string && data.filmSize.size() <= 32;
    }

    match /patientRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isAuthorized() && isValidId(recordId) && isValidPatientRecord(incoming()) && incoming().createdAt == request.time;
      allow update: if isAuthorized() && (isAdmin() || existing().userId == request.auth.uid) && 
                    isValidPatientRecord(incoming()) && 
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'name', 'age', 'invoice', 'filmType', 'count', 'radiographer', 'department', 'filmSize', 'updatedAt']);
      allow delete: if isAdmin() || (isAuthorized() && existing().userId == request.auth.uid);
    }

    // Film Stocks
    function isValidFilmStock(data) {
      // Required base for any stock record
      let required = ['date', 'filmType', 'userId', 'updatedAt'];
      // Max possible keys: date, filmType, receive, use, waste, userId, updatedAt, bf
      return data.keys().hasAll(required) &&
             data.keys().size() <= 8 &&
             data.date is string && data.date.size() <= 32 &&
             data.filmType is string && data.filmType.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.updatedAt == request.time &&
             (data.get('receive', 0) is number) &&
             (data.get('use', 0) is number) &&
             (data.get('waste', 0) is number) &&
             (data.get('bf', 0) is number);
    }

    match /filmStocks/{stockId} {
      allow read: if isSignedIn();
      allow create: if isAuthorized() && isValidId(stockId) && isValidFilmStock(incoming());
      allow update: if isAuthorized() && isValidId(stockId) && isValidFilmStock(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'filmType', 'receive', 'waste', 'bf', 'userId', 'updatedAt']);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /settings/general {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Radiographers
    function isValidRadiographer(data) {
      // Create schema (no updatedAt yet)
      let required = ['name', 'username', 'role', 'isActive', 'userId', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.name is string && data.name.size() <= 128 &&
             data.username is string && data.username.size() <= 128 &&
             data.role in ['admin', 'radiographer'] &&
             data.isActive is bool &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidRadiographerUpdate(data) {
       // Update schema (includes updatedAt)
       return data.name is string && data.name.size() <= 128 &&
              data.username is string && data.username.size() <= 128 &&
              data.role in ['admin', 'radiographer'] &&
              data.isActive is bool &&
              data.updatedAt == request.time;
    }

    match /radiographers/{radId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(radId) && isValidRadiographer(incoming());
      allow update: if isAdmin() && isValidRadiographerUpdate(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'username', 'phone', 'specialization', 'role', 'isActive', 'updatedAt']);
      allow delete: if isAdmin();
    }
  }
}
